{
  "name": "whatsapp-command-centre",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "start": "node app.js",
    "dev": "concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/web\"",
    "lint": "eslint . --ext .ts,.tsx",
    "db:generate": "npm run db:generate -w apps/backend",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "postinstall": "npm run build -w packages/shared && npm run build -w apps/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
